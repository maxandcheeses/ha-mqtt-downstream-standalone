# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Home Assistant ─────────────────────────────────────────────────────────────
HA_TOKEN=your_long_lived_access_token        # Profile → Security → Long-Lived Access Tokens

# ── MQTT Broker credentials ────────────────────────────────────────────────────
BROKER_PASSWORD=your_broker_password

# ── TLS certificates (base64-encoded PEM) ─────────────────────────────────────
# See docs/mqtt-tls.md for how to generate certs and encode them.
#
# Linux:   cat ca.crt | base64 -w 0
# macOS:   cat ca.crt | base64
#
BROKER_TLS_CA=                               # Required to enable TLS
BROKER_TLS_CERT=                             # Only needed for mutual TLS
BROKER_TLS_KEY=                              # Only needed for mutual TLS